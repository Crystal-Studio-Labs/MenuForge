# --- Branding & Colors ---
GUM_CONF="/home/crystal/.config/omarchy/current/theme/gum.env.conf"
if [ -f "$GUM_CONF" ]; then
    PRIMARY=$(grep "GUM_CHOOSE_CURSOR_FOREGROUND" "$GUM_CONF" | cut -d',' -f2 | tr -d '#')
    SECONDARY=$(grep "GUM_CHOOSE_HEADER_FOREGROUND" "$GUM_CONF" | cut -d',' -f2 | tr -d '#')
else
    PRIMARY="#00D7FF" # Cyan
    SECONDARY="#FFFFFF" # White
fi
ACCENT="#FCC624"
APP_DIR_USER="$HOME/.local/share/applications"

